# Neon Postgres
DATABASE_URL="postgres://user:password@host/db?sslmode=require"

# Web push — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
PUBLIC_VAPID_PUBLIC_KEY=""   # same as VAPID_PUBLIC_KEY

# Shared secret for /api/cron/reminders (Vercel sends it automatically)
CRON_SECRET=""
