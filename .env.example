# Neon Postgres — point DATABASE_URL at the dev branch, never at production.
# PROD_DATABASE_URL (main branch) is only read by scripts/backup.sh and for
# deliberate production schema pushes.
DATABASE_URL="postgres://user:password@dev-branch-host/db?sslmode=require"
PROD_DATABASE_URL="postgres://user:password@main-branch-host/db?sslmode=require"

# Web push — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
PUBLIC_VAPID_PUBLIC_KEY=""   # same as VAPID_PUBLIC_KEY

# Shared secret for /api/cron/reminders (Vercel sends it automatically)
CRON_SECRET=""
